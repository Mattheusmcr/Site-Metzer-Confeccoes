# ─────────────────────────────────────────
# BACKEND — Django
# ─────────────────────────────────────────

# Variáveis de ambiente (NUNCA suba isso)
backend/.env
backend/.env.*
!backend/.env.example

# Segredos e configurações locais
backend/metzker/settings_local.py

# Banco de dados local
backend/db.sqlite3
*.sqlite3

# Arquivos de mídia (imagens enviadas pelos usuários)
backend/media/

# Cache Python
backend/__pycache__/
backend/**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Ambiente virtual Python
backend/venv/
backend/env/
backend/.venv/

# Arquivos estáticos coletados (gerados pelo collectstatic)
backend/staticfiles/

# Logs
*.log
backend/logs/

# Arquivos do sistema
.DS_Store
Thumbs.db

# ─────────────────────────────────────────
# FRONTEND — React / Vite
# ─────────────────────────────────────────

# Variáveis de ambiente (NUNCA suba isso)
frontend/.env
frontend/.env.local
frontend/.env.production
!frontend/.env.example

# Dependências (pesadas demais para o Git)
frontend/node_modules/

# Build de produção (gerado pelo npm run build)
frontend/dist/

# Cache do Vite
frontend/.vite/

